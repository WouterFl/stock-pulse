APP_NAME="Stock Pulse"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://sp.wppf-development.com
APP_DOMAIN=sp.wppf-development.com
APP_KEY=base64:VERVANG_MET_php_artisan_key_generate_--show

# Compose-projectnaam (isoleert containers/volumes van andere apps op de VPS)
COMPOSE_PROJECT_NAME=stock-pulse

# Interne HTTP-poort (Caddy proxiet hiernaar)
APP_PORT=8003

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stderr
LOG_LEVEL=warning

# ── Database (MySQL-container) ──────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=stock_pulse
DB_USERNAME=stock_pulse
DB_PASSWORD=VERVANG_MET_STERK_WACHTWOORD
DB_ROOT_PASSWORD=VERVANG_MET_ROOT_WACHTWOORD

# ── Sessies / cache / queue ─────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
# Horizon vereist de redis queue-driver.
QUEUE_CONNECTION=redis

# ── Redis (redis-container) ─────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Reverb (realtime) ───────────────────────────────────────────────────────────
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=VERVANG
REVERB_APP_KEY=VERVANG
REVERB_APP_SECRET=VERVANG
# Intern: de app broadcast naar de reverb-container.
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http
# Externe poort waar Caddy /app/* naartoe proxiet.
REVERB_EXTERNAL_PORT=8083
# Client (browser) verbindt via Caddy over wss op het publieke domein.
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${APP_DOMAIN}"
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https

# ── Mail ────────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="alerts@sp.wppf-development.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Eerste admin (AdminUserSeeder) ──────────────────────────────────────────────
ADMIN_EMAIL=admin@sp.wppf-development.com
ADMIN_NAME="Stock Pulse Admin"
ADMIN_PASSWORD=VERVANG_MET_ADMIN_WACHTWOORD

# ── Quote providers (Sprint 2) ──────────────────────────────────────────────────
# Yahoo en Stooq werken zonder key; Finnhub is optioneel.
FINNHUB_API_KEY=
QUOTE_FETCH_TIMEOUT=10

# ── News providers (Sprint 3) ────────────────────────────────────────────────────
MARKETAUX_API_KEY=
NEWSAPI_API_KEY=
NEWS_FETCH_INTERVAL_MINUTES=5

# ── Alerts (Sprint 4) ─────────────────────────────────────────────────────────────
ALERT_DEFAULT_THRESHOLD_PERCENT=3.0
ALERT_DEFAULT_WINDOW_MINUTES=60
ALERT_STATISTICAL_PERIODS=20
ALERT_STATISTICAL_SIGMA=2.0

# ── Web Push / PWA (Sprint 5) ─────────────────────────────────────────────────────
# Genereer met: php artisan webpush:vapid --show  (of zet de keys uit lokaal)
VAPID_PUBLIC_KEY=VERVANG
VAPID_PRIVATE_KEY=VERVANG
VAPID_SUBJECT="mailto:wouter.flohr@gmail.com"
